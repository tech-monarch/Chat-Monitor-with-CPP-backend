# ─── Gemini Chat Monitor – Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Required: Your Google Gemini API key
# Obtain at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyBFjHnPoGdPuVNUDCH2cxFiFIX7husdj5k

# Optional: Model to use (default: gemini-2.5-flash)
# Options: gemini-2.5-flash | gemini-2.0-flash | gemini-1.5-pro
GEMINI_MODEL=gemini-2.5-flash

# Optional: Server port (default: 8080)
PORT=8080
